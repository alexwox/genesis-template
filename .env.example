# App
NODE_ENV=development
LOG_LEVEL=debug
SITE_URL=
NEXT_PUBLIC_APP_URL=

# Payments — choose `stripe` or `polar` (default: stripe)
PAYMENT_PROVIDER=stripe

# Stripe (when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Plan price IDs (see lib/payments/plans.ts)
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_CREDITS_TOPUP=

# Polar (when PAYMENT_PROVIDER=polar)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# production | sandbox
POLAR_SERVER=production
# Comma-separated product IDs per env var if multiple (see lib/payments/plans.ts)
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_YEARLY=
POLAR_PRODUCT_CREDITS_TOPUP=

# Database (Neon)
# Use a non-production branch URL for local/dev.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM=

# Object storage (R2/S3-compatible) — optional, fill when needed
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# AI — optional, fill when needed
OPENAI_API_KEY=

# PostHog (product analytics — EU Cloud defaults below)
NEXT_PUBLIC_POSTHOG_KEY=
# Browser SDK posts to this URL; keep as /ph so Next.js rewrites proxy to PostHog (see next.config.ts).
NEXT_PUBLIC_POSTHOG_HOST=/ph
# Server SDK (posthog-node) ingests here directly — not the /ph rewrite. Use EU or US ingest host to match your project.
POSTHOG_HOST=https://eu.i.posthog.com
